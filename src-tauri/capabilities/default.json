{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-read-dir",
    "fs:allow-write",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:scope-desktop-recursive",
    "fs:scope-home-recursive"
  ]
}