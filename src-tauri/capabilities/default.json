{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$DESKTOP/**/chat_history.json" },
        { "path": "$DESKTOP/**/wiki/**" },
        { "path": "$HOME/**/chat_history.json" },
        { "path": "$HOME/**/wiki/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$DESKTOP/**/chat_history.json" },
        { "path": "$DESKTOP/**/wiki/**" },
        { "path": "$HOME/**/chat_history.json" },
        { "path": "$HOME/**/wiki/**" }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$DESKTOP/**/chat_history.json" },
        { "path": "$DESKTOP/**/wiki/**" },
        { "path": "$HOME/**/chat_history.json" },
        { "path": "$HOME/**/wiki/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$DESKTOP/**/wiki/**" },
        { "path": "$HOME/**/wiki/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$DESKTOP/**/chat_history.json" },
        { "path": "$DESKTOP/**/wiki/**" },
        { "path": "$HOME/**/chat_history.json" },
        { "path": "$HOME/**/wiki/**" }
      ]
    },
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:scope-desktop-recursive",
    "fs:scope-home-recursive"
  ]
}